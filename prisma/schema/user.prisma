model User {
    id           String       @id @default(uuid())
    name         String       @db.VarChar(250)
    email        String       @unique
    password     String
    activeStatus ActiveStatus @default(ACTIVE)
    role         Role         @default(USER)
    createdAt    DateTime     @default(now())
    updateAt     DateTime     @updatedAt
    profile      Profile?

    posts Post[]
    comments Comment[]

    @@map("users")
}
